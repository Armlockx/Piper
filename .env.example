# Supabase (new Piper project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq
GROQ_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron (Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Admin access (comma-separated; human users only — not bots)
ADMIN_EMAILS=
ADMIN_USER_IDS=

# Optional — timezone for daily cron planning (default America/Sao_Paulo)
PIPER_TZ=America/Sao_Paulo

# Optional phase 2 — rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
